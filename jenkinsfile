pipeline {
    agent any

    environment {
        IMAGE_NAME = "championsleague-app"
        VM_IP = "192.168.56.101"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t $IMAGE_NAME ."
            }
        }

        stage('Run Container') {
            steps {
                sh """
                docker rm -f app || true
                docker run -d -p 3000:3000 --name app $IMAGE_NAME
                """
                sleep 5
            }
        }

        stage('Run Tests') {
            steps {
                sh "TEST_HOST=$VM_IP npm test"
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished'
        }
        failure {
            echo '❌ Pipeline failed'
        }
        success {
            echo '✅ Pipeline succeeded'
        }
    }
}
